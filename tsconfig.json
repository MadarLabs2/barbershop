{
  "compilerOptions": {
    "allowJs": true,
    "jsx": "react-native",
    "moduleResolution": "node",
    "noEmit": true,
    "target": "ESNext",
    "strict": false,
    "skipLibCheck": true
  },
  "include": [
    "App.js",
    "app.config.js",
    "src/**/*.js",
    "src/**/*.jsx",
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "whatsapp"
  ],
  "extends": "expo/tsconfig.base"
}
